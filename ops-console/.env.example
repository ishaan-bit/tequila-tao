# =====================================================================
# Tequila Tao — Ops Console environment variables
# =====================================================================
# Copy this file to `.env.local` for local development.
# In production these are set in the Vercel project dashboard
# (Settings → Environment Variables).
# =====================================================================

# ---------------------------------------------------------------------
# CLIENT (Vite) — exposed to the browser. Safe to be public.
# These configure the Firebase JS SDK used ONLY for admin Google sign-in.
# ---------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSyBKrCckFoR_CbQPAGScoZCwqgAI81MzDa0
VITE_FIREBASE_AUTH_DOMAIN=tequila-tao.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tequila-tao
VITE_FIREBASE_STORAGE_BUCKET=tequila-tao.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=98857517217
VITE_FIREBASE_APP_ID=1:98857517217:web:7144c1768c4f1809d270e0

# Comma-separated list of admin emails. CLIENT-SIDE UX GATING ONLY.
# (The real security boundary is ADMIN_EMAILS on the server, below.)
VITE_ADMIN_EMAILS=kumar.ishaan93@gmail.com

# ---------------------------------------------------------------------
# SERVER (Vercel serverless functions) — SECRET. Never exposed to browser.
# ---------------------------------------------------------------------

# The full JSON of a Firebase service-account private key, as a single
# string (paste the entire downloaded JSON file's contents here).
# Firebase console → Project settings → Service accounts →
#   "Generate new private key".
# Example shape (DO NOT use this — generate your own):
# {"type":"service_account","project_id":"tequila-tao","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@tequila-tao.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"tequila-tao", ... }

# Comma-separated list of admin emails allowed to use the API.
# THIS is the real security boundary — every API request is rejected
# unless the verified Google token's email is in this list.
ADMIN_EMAILS=kumar.ishaan93@gmail.com
